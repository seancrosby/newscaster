# Optional: Ollama configuration (defaults to llama3 and http://localhost:11434)
OLLAMA_MODEL=llama3
OLLAMA_BASE_URL=http://localhost:11434

# SMTP Credentials
EMAIL_USER=resend
EMAIL_PASS=your_resend_api_key_here
# The verified sender email (must be verified in Resend)
SENDER_EMAIL=onboarding@resend.dev

# Optional: SMTP host and port
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USE_TLS=True
